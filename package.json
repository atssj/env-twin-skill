{
  "name": "env-twin-skill",
  "version": "1.0.0",
  "description": "Powerful MCP server and AI agent skill for synchronizing, managing, and templating environment variables (.env) across single and monorepo projects.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "env",
    "mcp-server",
    "ai-assistant",
    "monorepo",
    "dotenv",
    "cursor",
    "mcp",
    "environment-variables",
    "sync",
    "llm",
    "agent-skill",
    "ai-agent",
    "claude",
    "configuration-management",
    "env-twin"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "env-twin-mcp": "./dist/mcp-server/index.js"
  },
  "agents": {
    "skills": [
      "./skills/env-twin"
    ]
  },
  "scripts": {
    "build": "tsc -p .",
    "start": "node ./dist/mcp-server/index.js",
    "dev": "ts-node ./mcp-server/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector node ./dist/mcp-server/index.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
